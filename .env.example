# ============================================================
# .env.example — Autonomous Commerce AI Agent
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Phase 1–2: Required ──────────────────────────────────────

# Serper.dev Google Shopping API
# Sign up free at https://serper.dev — 2,500 searches, no credit card
SERPER_API_KEY=your_serper_api_key_here

# Groq LLM API (Decision Agent + fallback search)
# Sign up free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ── Phase 4+: Algorand testnet ────────────────────────────────

# 25-word mnemonic for your testnet account
# Generate: python -c "from algosdk import account, mnemonic; sk,pk=account.generate_account(); print(mnemonic.from_private_key(sk))"
# Fund at: https://testnet.algoexplorer.io/dispenser
ALGORAND_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24 word25

# Algorand receiver address (can be same as sender for testing)
ALGORAND_RECEIVER=your_algorand_testnet_address_here

# ── Development flags ─────────────────────────────────────────

# Set to "true" to skip all API calls and use mock data only
# Useful for offline development and CI/CD
MOCK_ONLY=false

# FastAPI server settings
API_HOST=0.0.0.0
API_PORT=8000

# Optional: Protect all /api routes except health. If empty, runs unauthenticated.
API_SECRET_KEY=your_secret_here

# CORS origin for frontend dev server
FRONTEND_ORIGIN=http://localhost:3000

# ── Frontend (Next.js) ────────────────────────────────────────
# These must be prefixed NEXT_PUBLIC_ to be available in the browser.

# Backend API base URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# WalletConnect v2 project ID — prevents "dapp not responding" in Pera Wallet QR.
# Register free at https://cloud.walletconnect.com → Create Project → get Project ID.
# Without this, Pera mobile wallet may show "dapp not responding" on QR scan.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ── x402 Price Lock (Phase 7) ─────────────────────────────────
# Algorand address that receives 0.1 ALGO per price-lock verification.
# This must be funded on testnet before use.
KARTIQ_MERCHANT_WALLET=your_algorand_testnet_address_here

# GoPlausible x402 facilitator (Algorand testnet)
FACILITATOR_URL=https://facilitator.goplausible.xyz

# Algorand network — testnet only for now.
ALGORAND_NETWORK=testnet

# ── Performance tuning ────────────────────────────────────────
# Number of threads in the FastAPI worker thread pool (default: 20).
# Increase if you see thread exhaustion under load.
THREAD_POOL_SIZE=20

# Comma-separated queries to pre-warm the search cache on startup.
# Leave empty to skip pre-warming.
PREWARM_QUERIES=gaming laptop under 80000,best phone under 30000,wireless earbuds
